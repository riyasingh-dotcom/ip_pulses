# Local development — copy to .env.local and fill in values
# Production — copy to .env.production, fill in values, then run:
#   railway variables set --from-file .env.production

IPINFO_TOKEN=

# Auto-injected by Railway Postgres/Redis services in production
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ip_pulses
REDIS_URL=redis://localhost:6379
